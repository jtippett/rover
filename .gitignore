# Elixir
/_build/
/cover/
/deps/
/doc/
/.fetch
erl_crash.dump
*.ez
*.beam
/config/*.secret.exs
.elixir_ls/

# Precompiled rover_runtime binary, downloaded into priv/native at `mix compile`
# by the :rover_download compiler. Never committed — fetched per release.
/priv/native/

# Rust
/native/*/target/
# Cargo.lock is committed: rover_runtime is a binary crate, and pinning
# the full dep tree (including Servo's revision) matters for reproducible
# builds in CI and on users' machines.

# Servo source checkout (local convenience only — library depends on servo via git in Cargo.toml)
/servo_rust/

# ExUnit @tag :tmp_dir scratch (test/rover/precompiled_test.exs)
/tmp/

# checksum-rover_runtime.exs is committed (regenerated per release, verifies the
# downloaded binary) — do NOT ignore it.

# macOS
.DS_Store
